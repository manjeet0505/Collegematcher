generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  password         String?
  image            String?
  createdAt        DateTime          @default(now())
  savedColleges    SavedCollege[]
  savedComparisons SavedComparison[]
  questions        Question[]
  answers          Answer[]
}

model College {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  location         String
  city             String
  state            String
  type             String
  rating           Float
  totalFees        Int
  establishedYear  Int
  imageUrl         String?
  description      String
  website          String?
  placementAvg     Int
  placementHighest Int
  placementPercent Float
  naacGrade        String
  nirfRank         Int?
  courses          Course[]
  reviews          Review[]
  savedBy          SavedCollege[]
  questions        Question[]
  createdAt        DateTime       @default(now())
}

model Course {
  id        String  @id @default(cuid())
  name      String
  duration  String
  fees      Int
  seats     Int
  college   College @relation(fields: [collegeId], references: [id])
  collegeId String
}

model Review {
  id        String   @id @default(cuid())
  author    String
  rating    Float
  comment   String
  year      Int
  college   College  @relation(fields: [collegeId], references: [id])
  collegeId String
  createdAt DateTime @default(now())
}

model SavedCollege {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  college   College  @relation(fields: [collegeId], references: [id])
  collegeId String
  createdAt DateTime @default(now())

  @@unique([userId, collegeId])
}

model SavedComparison {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  collegeIds String[]
  createdAt  DateTime @default(now())
}

model Question {
  id        String   @id @default(cuid())
  title     String
  body      String?
  userId    String
  collegeId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  answers   Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  body       String
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}